OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-nano

# Optional alternative provider compatibility
NVIDIA_API_KEY=
NVIDIA_MODEL=
OPENAI_BASE_URL=
NVIDIA_BASE_URL=

# API/CORS
ALLOWED_ORIGINS=https://site-sage-eta-18.vercel.app,http://localhost:3000,http://localhost:3004

# Graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
MEMGRAPH_URL=
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_SCHEME=bolt
MEMGRAPH_USERNAME=your_neo4j_username
MEMGRAPH_PASSWORD=your_neo4j_password
MEMGRAPH_SSL=false

# Vector store
# Use /data/chroma on Railway with a mounted persistent volume.
CHROMA_PATH=./chroma_db

# Supabase/Postgres metadata store
# Use the Supabase pooled/direct Postgres connection string here.
SUPABASE_DB_URL=
POSTGRES_DSN=

# Optional Slack bot
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
